{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (customer, staff, or admin).",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "staff", "customer"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created."
        }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A beauty or skincare service offered by the salon.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the service."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the service."
        },
        "price": {
          "type": "number",
          "description": "The price of the service in NGN."
        },
        "duration": {
          "type": "number",
          "description": "The duration of the service in minutes."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "An image representing the service."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the service was added."
        }
      },
      "required": ["name", "description", "price", "duration", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "An appointment booking for a service.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who made the booking."
        },
        "serviceId": {
          "type": "string",
          "description": "The ID of the booked service."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the appointment."
        },
        "time": {
          "type": "string",
          "description": "The time of the appointment."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "cancelled", "completed"],
          "description": "The status of the booking."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the booking was created."
        }
      },
      "required": ["userId", "serviceId", "date", "time", "status", "createdAt"]
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "description": "An AI-generated image or video for the salon's gallery.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["image", "video"],
          "description": "The type of media."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the media."
        },
        "prompt": {
          "type": "string",
          "description": "The prompt used to generate the media."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the media was added."
        }
      },
      "required": ["type", "url", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/services/{serviceId}": {
      "schema": {
        "$ref": "#/entities/Service"
      },
      "description": "Stores salon services."
    },
    "/bookings/{bookingId}": {
      "schema": {
        "$ref": "#/entities/Booking"
      },
      "description": "Stores appointment bookings."
    },
    "/gallery/{itemId}": {
      "schema": {
        "$ref": "#/entities/GalleryItem"
      },
      "description": "Stores gallery media."
    }
  }
}
